# ── MongoDB Atlas ──────────────────────────────────────────
# Atlas → 클러스터 → Connect → Drivers(Node.js)에서 복사한 문자열.
# <db_password>를 실제 비밀번호로 바꾸고, .mongodb.net/ 뒤에 DB이름(teamcal)을 넣으세요.
MONGODB_URI="mongodb+srv://teamcal:<db_password>@cluster0.xxxxx.mongodb.net/teamcal?retryWrites=true&w=majority&appName=Cluster0"

# ── NextAuth ───────────────────────────────────────────────
# 터미널에서 생성: openssl rand -base64 32
NEXTAUTH_SECRET="여기에_생성한_랜덤값"
NEXTAUTH_URL="http://localhost:3000"

# ── (선택) Vercel Blob — 첨부파일 저장 시 ──────────────────
# BLOB_READ_WRITE_TOKEN=""

# ── (선택) 텔레그램 알림 봇 ─────────────────────────────────
# @BotFather에서 봇 생성 후 토큰 입력. 미설정 시 텔레그램 알림은 조용히 비활성화.
# 사용자는 봇과 대화 시작 후 설정 페이지(내 계정)에서 자신의 챗 ID를 등록.
# TELEGRAM_BOT_TOKEN=""

# ── (선택) 크론 보호 — Vercel 프로젝트 env에도 설정 ─────────
# 마감 알림 크론(/api/cron/reminders)이 이 값으로 인증됨. openssl rand -base64 32
# CRON_SECRET=""
